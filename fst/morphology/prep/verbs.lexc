0 VTI_Class ;
@D.diminutive.DIM@@R.infl.VTI-m@@P.infl.VTI-io@+V+TI+Der/Dim:@D.diminutive.DIM@@R.infl.VTI-m@@P.infl.VTI-io@%>as^DIMi VTI_Class ;
