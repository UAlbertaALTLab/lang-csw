0 VAI_Class ;
@D.diminutive.DIM@@R.infl.VAI-ae@@P.infl.VAI-io@+V+AI+Der/Dim:@D.diminutive.DIM@@R.infl.VAI-ae@@P.infl.VAI-io@%>s^DIMi VAI_Class ;
