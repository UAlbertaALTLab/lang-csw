LEXICON VII_Diminutive
0 VII_Class ;
@D.diminutive.DIM@@R.infl.VII-n@+V+II+Der/Dim:@D.diminutive.DIM@@R.infl.VII-n@%>s^DIMi VII_Class ;
@D.diminutive.DIM@@R.infl.VII-v@+V+II+Der/Dim:@D.diminutive.DIM@@R.infl.VII-v@%>s^DIMi VII_Class ;

